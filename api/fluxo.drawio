        </mxCell>
        <mxCell id="bgState" value="Estado compartilhado" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontSize=14;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1320" y="1360" width="300" height="290" as="geometry" />
        </mxCell>

        <!-- LEFT COLUMN: startup flow -->
